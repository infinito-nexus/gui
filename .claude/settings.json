{
  "env": {
    "GIT_CONFIG_COUNT": "1",
    "GIT_CONFIG_KEY_0": "commit.gpgsign",
    "GIT_CONFIG_VALUE_0": "false"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Edit",
      "Read",
      "Write",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:infinito.nexus)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:pypi.org)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:s.infinito.nexus)",
      "WebSearch",
      "WebFetch(domain:*.blob.core.windows.net)",
      "WebFetch(domain:auth.docker.io)",
      "WebFetch(domain:cdn.playwright.dev)",
      "WebFetch(domain:playwright.download.prss.microsoft.com)",
      "Bash(docker network *)",
      "WebFetch(domain:www.google.com)",
      "Bash(DOCKER_CONFIG=/tmp/docker-config docker compose up -d api)",
      "Bash(DOCKER_CONFIG=/tmp/docker-config docker compose --profile test down -v --remove-orphans)",
      "Bash(DOCKER_CONFIG=/tmp/docker-config docker compose --profile test down -v)",
      "Bash(export DOCKER_CONFIG=/tmp/docker-config DOCKER_BUILDKIT=0 PLAYWRIGHT_BROWSERS_PATH=/tmp/playwright DOCKER_SOCKET_GID=959)",
      "Bash(make e2e-dashboard-local *)",
      "Bash(docker exec *)",
      "Bash(docker run --rm --network infinito-deployer alpine:latest *)",
      "Bash(docker run --rm -v *)",
      "Bash(docker rm -f *)",
      "Bash(docker network prune*)",
      "Bash(docker stop *)",
      "Bash(make *)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ],
    "deny": [
      "Bash(git branch -D*)",
      "Bash(git clean*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(sudo*)"
    ],
    "ask": [
      "Bash(curl*)",
      "Bash(docker build*)",
      "Bash(docker push*)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ],
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "*.docker.com",
        "*.github.com",
        "*.githubusercontent.com",
        "*.infinito.nexus",
        "*.npmjs.org",
        "*.pythonhosted.org",
        "ghcr.io",
        "github.com",
        "infinito.nexus",
        "letsencrypt.org",
        "pypi.org",
        "raw.githubusercontent.com",
        "registry-1.docker.io",
        "registry.npmjs.org"
      ],
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        ".",
        "/tmp",
        "~/.ansible",
        "~/.cache/pip",
        "~/.cache/pre-commit",
        "~/.npm",
        "~/.venvs"
      ],
      "denyRead": [
        "~/.aws",
        "~/.config/gcloud",
        "~/.gnupg",
        "~/.kube",
        "~/.ssh"
      ]
    }
  }
}
